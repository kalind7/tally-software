generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GroupNature {
  Asset
  Liability
  Income
  Expense
}

enum BalanceType {
  Dr
  Cr
}

enum VoucherType {
  Payment
  Receipt
  Contra
  Journal
  Sales
  Purchase
}

enum EntryType {
  Dr
  Cr
}

enum BillRefType {
  New
  Against
  OnAccount
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Company {
  id             String        @id @default(cuid())
  name           String
  mailingName    String?
  address        String?
  fyStartMonth   Int           @default(4)
  booksBeginDate DateTime
  currency       String        @default("INR")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  users          User[]
  ledgerGroups   LedgerGroup[]
  ledgers        Ledger[]
  vouchers       Voucher[]
  billReferences BillReference[]
}

model LedgerGroup {
  id        String      @id @default(cuid())
  companyId String
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  parentId  String?
  parent    LedgerGroup? @relation("GroupHierarchy", fields: [parentId], references: [id])
  children  LedgerGroup[] @relation("GroupHierarchy")
  nature    GroupNature
  isPrimary Boolean     @default(true)
  ledgers   Ledger[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([companyId, name])
}

model Ledger {
  id             String          @id @default(cuid())
  companyId      String
  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  groupId        String
  group          LedgerGroup     @relation(fields: [groupId], references: [id])
  name           String
  openingBalance Decimal         @default(0) @db.Decimal(18, 2)
  openingType    BalanceType     @default(Dr)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  voucherLines   VoucherLine[]
  billReferences BillReference[]

  @@unique([companyId, name])
}

model Voucher {
  id        String        @id @default(cuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      VoucherType
  number    String
  date      DateTime
  narration String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  lines     VoucherLine[]

  @@unique([companyId, type, number])
  @@index([companyId, date])
}

model VoucherLine {
  id          String         @id @default(cuid())
  voucherId   String
  voucher     Voucher        @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  ledgerId    String
  ledger      Ledger         @relation(fields: [ledgerId], references: [id])
  amount      Decimal        @db.Decimal(18, 2)
  entryType   EntryType
  billRef     BillReference?
}

model BillReference {
  id            String       @id @default(cuid())
  companyId     String
  company       Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ledgerId      String
  ledger        Ledger       @relation(fields: [ledgerId], references: [id])
  voucherLineId String?      @unique
  voucherLine   VoucherLine? @relation(fields: [voucherLineId], references: [id], onDelete: SetNull)
  billNo        String
  billDate      DateTime
  dueDate       DateTime?
  amount        Decimal      @db.Decimal(18, 2)
  refType       BillRefType  @default(New)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([companyId, billDate])
  @@index([companyId, ledgerId])
}
